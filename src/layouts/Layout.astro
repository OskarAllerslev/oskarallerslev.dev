---
import { Analytics } from '@vercel/analytics/react';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="da" class="overflow-x-hidden max-w-full">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Oskar Allerslev's Portfolio" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link
			rel="stylesheet"
			href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
			integrity="sha384-n8MVd4RsNIU0KOVEMeaOVTGFekkVanpVyyfqoYoX4AFFOAF5ma9DCZaNuBBP_3sM"
			crossorigin="anonymous"
		/>
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<div class="fixed inset-0 overflow-hidden z-[-1] pointer-events-none">
			<div class="aurora-teal absolute h-96 w-96 rounded-full bg-teal-500 opacity-20 blur-3xl"></div>
			<div class="aurora-purple absolute h-96 w-96 rounded-full bg-purple-500 opacity-20 blur-3xl"></div>
			<div class="aurora-emerald absolute h-96 w-96 rounded-full bg-emerald-500 opacity-20 blur-3xl"></div>
		</div>
		<slot />
		<Analytics />
	</body>
</html>
<style is:global>
	html {
		font-family: 'Inter Variable', sans-serif;
		scroll-behavior: smooth;
	}
	body {
		background-color: #09090b; /* zinc-950 */
		color: #d4d4d8;
		overflow-x: hidden;
	}

	.aurora-teal {
		top: -20%;
		left: -10%;
		animation: aurora 20s infinite linear alternate;
	}
	.aurora-purple {
		top: 50%;
		left: 50%;
		animation: aurora 25s infinite linear alternate;
		animation-delay: 3s;
	}
	.aurora-emerald {
		bottom: -20%;
		right: -10%;
		animation: aurora 22s infinite linear alternate;
		animation-delay: 6s;
	}

	@keyframes aurora {
		0% {
			transform: translate(0, 0) rotate(0deg) scale(1);
		}
		50% {
			transform: translate(25vw, 30vh) rotate(180deg) scale(1.2);
		}
		100% {
			transform: translate(0, 0) rotate(360deg) scale(1);
		}
	}

	.no-scrollbar::-webkit-scrollbar {
		display: none;
	}
	.no-scrollbar {
		-ms-overflow-style: none; /* IE and Edge */
		scrollbar-width: none; /* Firefox */
	}

	@keyframes fadeIn {
		from {
			opacity: 0;
			transform: translateY(10px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
</style>
