---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Oskar Allerslev | Portfolio">
	<main class="container mx-auto max-w-3xl px-6 py-20">
		<!-- Hero Section -->
		<section class="mb-16">
			<h1 class="text-4xl font-bold tracking-tight text-zinc-100 sm:text-5xl">
				Oskar Allerslev
			</h1>
			<h2 class="mt-2 text-lg font-medium tracking-tight text-zinc-300 sm:text-xl">
				Actuarial Mathematics & Quantitative Infrastructure
			</h2>
			<p class="mt-6 max-w-2xl text-base text-zinc-400">
				Specializing in stochastic modeling, martingale pricing theorems, and high-performance systems programming.
				Building robust, low-latency infrastructure for quantitative finance and insurance.
			</p>
		</section>

		<!-- Core Tech Stack -->
		<section class="mb-16">
			<h3 class="text-sm font-semibold uppercase tracking-widest text-zinc-500">
				Core Tech Stack
			</h3>
			<div class="mt-4 flex flex-wrap gap-2">
				<span class="rounded bg-zinc-800 px-2 py-1 font-mono text-sm font-medium text-accent-hover">Rust</span>
				<span class="rounded bg-zinc-800 px-2 py-1 font-mono text-sm font-medium text-accent-hover">C++</span>
				<span class="rounded bg-zinc-800 px-2 py-1 font-mono text-sm font-medium text-accent-hover">R (Rcpp / dbplyr)</span>
				<span class="rounded bg-zinc-800 px-2 py-1 font-mono text-sm font-medium text-accent-hover">Python</span>
				<span class="rounded bg-zinc-800 px-2 py-1 font-mono text-sm font-medium text-accent-hover">SQL</span>
			</div>
		</section>

		<!-- Featured Infrastructure -->
		<section class="mb-16">
			<h3 class="text-sm font-semibold uppercase tracking-widest text-zinc-500">
				Featured Infrastructure
			</h3>
			<div class="mt-4 grid gap-8">
				<div class="rounded-lg border border-zinc-800 bg-zinc-900 p-4 transition-colors hover:border-accent">
					<h4 class="font-bold text-zinc-100">Stock Value-at-Risk API</h4>
					<p class="mt-2 text-zinc-400">
						API infrastructure for lightning-fast VaR calculations and ticker data handling.
					</p>
					<div class="mt-3">
						<span class="rounded bg-zinc-800 px-2 py-1 font-mono text-xs font-medium text-accent-hover">Rust</span>
					</div>
				</div>
				<div class="rounded-lg border border-zinc-800 bg-zinc-900 p-4 transition-colors hover:border-accent">
					<h4 class="font-bold text-zinc-100">Electricity Price Modeling</h4>
					<p class="mt-2 text-zinc-400">
						Modeling electricity spot prices using fractional Brownian motions.
					</p>
					<div class="mt-3 flex flex-wrap gap-2">
						<span class="rounded bg-zinc-800 px-2 py-1 font-mono text-xs font-medium text-accent-hover">R</span>
						<span class="rounded bg-zinc-800 px-2 py-1 font-mono text-xs font-medium text-accent-hover">fBM</span>
						<span class="rounded bg-zinc-800 px-2 py-1 font-mono text-xs font-medium text-accent-hover">SDEs</span>
					</div>
				</div>
				<div class="rounded-lg border border-zinc-800 bg-zinc-900 p-4 transition-colors hover:border-accent">
					<h4 class="font-bold text-zinc-100">Quantitative Risk Dashboards</h4>
					<p class="mt-2 text-zinc-400">
						High-performance data visualization and data pipelines for risk analysis.
					</p>
					<div class="mt-3 flex flex-wrap gap-2">
						<span class="rounded bg-zinc-800 px-2 py-1 font-mono text-xs font-medium text-accent-hover">R</span>
						<span class="rounded bg-zinc-800 px-2 py-1 font-mono text-xs font-medium text-accent-hover">Shiny</span>
						<span class="rounded bg-zinc-800 px-2 py-1 font-mono text-xs font-medium text-accent-hover">C++</span>
					</div>
				</div>
			</div>
		</section>

		<!-- Terminal / Contact -->
		<section>
			<div class="rounded-lg border border-zinc-800 bg-black p-4 font-mono text-sm text-zinc-300">
				<div class="flex items-center">
					<span class="text-terminal-green">oskar@oskarallerslev.dev</span>
					<span class="text-zinc-500">:</span>
					<span class="text-blue-400">~</span>
					<span class="text-zinc-500">$</span>
					<span class="ml-2 animate-pulse">./contact.sh</span>
				</div>
				<div class="mt-2">
					<div class="flex">
						<span class="w-16 shrink-0 text-zinc-500">GITHUB</span>
						<a href="https://github.com/OskarAllerslev" target="_blank" rel="noopener noreferrer" class="text-accent-hover hover:underline">https://github.com/OskarAllerslev</a>
					</div>
					<div class="flex">
						<span class="w-16 shrink-0 text-zinc-500">EMAIL</span>
						<a href="mailto:Oskar.m1660@gmail.com" class="text-accent-hover hover:underline">Oskar.m1660@gmail.com</a>
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>
