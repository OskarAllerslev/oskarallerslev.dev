---
import Layout from '../layouts/Layout.astro';
import RustApiExplorer from '../components/RustApiExplorer.jsx';
import FbmSimulator from '../components/FbmSimulator.jsx';
import TerminalSession from '../components/TerminalSession.jsx';

const components = {
	RustApiExplorer,
	FbmSimulator,
};

const projects = [
	{
		title: 'First Rust API (Stock VaR)',
		href: 'https://github.com/OskarAllerslev/first-rust-api',
		description:
			'A high-performance backend built in Rust using Axum. Fetches ticker data and calculates Historical Value at Risk (VaR) based on continuous returns and empirical quantiles.',
		tags: ['Rust', 'Axum', 'API'],
		component: 'RustApiExplorer',
	},
	{
		title: 'Rough Volatility Monte Carlo Pricer',
		href: 'https://github.com/OskarAllerslev/Rough-Volatility-Monte-Carlo-Pricer',
		description:
			'Advanced derivative pricing framework based on fractional Brownian motions (fBM). Solves Stochastic Differential Equations (SDEs) to capture the roughness of electricity spot prices and financial markets.',
		tags: ['C++', 'Math', 'SDEs', 'fBM'],
		component: 'FbmSimulator',
	},
	{
		title: 'Nitor Energy Forecasting Competition 2026',
		href: 'https://github.com/OskarAllerslev/Nitor-energy-competition-2026',
		description:
			'Predictive machine learning pipeline forecasting highly volatile energy spot prices across 6 distinct markets. Optimized for RMSE utilizing specialized XGBoost models and domain-specific meteorological features.',
		tags: ['R', 'tidymodels', 'XGBoost', 'Machine Learning'],
	},
	{
		title: 'Lifepack (R Package)',
		href: 'https://github.com/OskarAllerslev/lifepack',
		description:
			'Comprehensive R package for life insurance mathematics. Implements robust object-oriented programming (OOP), unit testing, and full roxygen2 documentation for production use.',
		tags: ['R', 'devtools', 'OOP', 'Unit Testing'],
	},
];
---

<Layout title="Oskar Allerslev | Portfolio">
	<main class="container mx-auto max-w-3xl px-6 py-20">
		<!-- Hero Section -->
		<section class="mb-16">
			<h1 class="text-4xl font-bold tracking-tight text-zinc-100 sm:text-5xl">Oskar Allerslev</h1>
			<h2 class="mt-2 text-lg font-medium tracking-tight text-zinc-300 sm:text-xl">
				Actuarial Mathematics & Quantitative Infrastructure
			</h2>
			<p class="mt-6 max-w-2xl text-base text-zinc-400">
				Specializing in stochastic modeling, martingale pricing theorems, and high-performance systems
				programming. Building robust, low-latency infrastructure for quantitative finance and insurance.
			</p>
		</section>

		<!-- Core Tech Stack -->
		<section class="mb-16">
			<h3 class="text-sm font-semibold uppercase tracking-widest text-zinc-500">Core Tech Stack</h3>
			<div class="mt-4 flex flex-wrap gap-2">
				<span class="rounded bg-zinc-800 px-2 py-1 font-mono text-sm font-medium text-accent-hover">Rust</span>
				<span class="rounded bg-zinc-800 px-2 py-1 font-mono text-sm font-medium text-accent-hover">C++</span>
				<span class="rounded bg-zinc-800 px-2 py-1 font-mono text-sm font-medium text-accent-hover">R</span>
				<span class="rounded bg-zinc-800 px-2 py-1 font-mono text-sm font-medium text-accent-hover">Python</span>
				<span class="rounded bg-zinc-800 px-2 py-1 font-mono text-sm font-medium text-accent-hover">SQL</span>
				<span class="rounded bg-zinc-800 px-2 py-1 font-mono text-sm font-medium text-accent-hover">XGBoost</span>
			</div>
		</section>

		<!-- Featured Infrastructure -->
		<section class="mb-16">
			<h3 class="text-sm font-semibold uppercase tracking-widest text-zinc-500">
				Featured Infrastructure
			</h3>
			<div class="mt-4 grid gap-8">
				{
					projects.map((project) => {
						const ProjectComponent = project.component ? components[project.component] : null;
						return project.component ? (
							<div class="group rounded-lg border border-zinc-800 bg-zinc-900 p-4 transition-all duration-300 hover:-translate-y-1 hover:border-accent">
								<a href={project.href} target="_blank" rel="noopener noreferrer" class="hover:underline">
									<h4 class="font-bold text-zinc-100">{project.title}</h4>
								</a>
								<p class="mt-2 text-zinc-400">{project.description}</p>
								{ProjectComponent && <ProjectComponent client:load />}
								<div class="mt-3 flex flex-wrap gap-2">
									{project.tags.map((tag) => (
										<span class="rounded bg-zinc-800 px-2 py-1 font-mono text-xs font-medium text-accent-hover group-hover:text-accent">
											{tag}
										</span>
									))}
								</div>
							</div>
						) : (
							<a
								href={project.href}
								target="_blank"
								rel="noopener noreferrer"
								class="block group rounded-lg border border-zinc-800 bg-zinc-900 p-4 transition-all duration-300 hover:-translate-y-1 hover:border-accent"
							>
								<h4 class="font-bold text-zinc-100">{project.title}</h4>
								<p class="mt-2 text-zinc-400">{project.description}</p>
								<div class="mt-3 flex flex-wrap gap-2">
									{project.tags.map((tag) => (
										<span class="rounded bg-zinc-800 px-2 py-1 font-mono text-xs font-medium text-accent-hover group-hover:text-accent">
											{tag}
										</span>
									))}
								</div>
							</a>
						);
					})
				}
			</div>
		</section>

		<!-- Terminal / Contact -->
		<section>
			<TerminalSession client:load />
		</section>
	</main>
</Layout>

<style>
	#terminal-input {
		background: transparent;
		border: none;
		outline: none;
		color: inherit;
		font-family: inherit;
		font-size: inherit;
		width: 100%;
	}
	#terminal-input:focus {
		outline: none;
		box-shadow: none;
	}
</style>
