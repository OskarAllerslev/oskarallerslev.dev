---
import Layout from '../layouts/Layout.astro';
import RustApiExplorer from '../components/RustApiExplorer.jsx';
import FbmSimulator from '../components/FbmSimulator.jsx';
import GitHubCard from '../components/GitHubCard.jsx';
import LeetCodeCard from '../components/LeetCodeCard.jsx';
import ProfileImageCard from '../components/ProfileImageCard.jsx';
import ExperienceCard from '../components/ExperienceCard.jsx';
import BeyondCodeCard from '../components/BeyondCodeCard.jsx';
import TechStackCard from '../components/TechStackCard.jsx';
import { BlockMath, InlineMath } from 'react-katex';

const projects = [
	{
		title: 'First Rust API (Stock VaR)',
		href: 'https://github.com/OskarAllerslev/first-rust-api',
		description:
			'A high-performance backend built in Rust using Axum. Fetches ticker data and calculates Historical Value at Risk (VaR) based on continuous returns and empirical quantiles.',
		tags: ['Rust', 'Axum', 'API'],
		component: 'RustApiExplorer',
	},
	{
		title: 'Rough Volatility Monte Carlo Pricer',
		href: 'https://github.com/OskarAllerslev/Rough-Volatility-Monte-Carlo-Pricer',
		description:
			'Advanced derivative pricing framework based on fractional Brownian motions (fBM). Solves Stochastic Differential Equations (SDEs) to capture the roughness of electricity spot prices and financial markets.',
		tags: ['C++', 'Math', 'SDEs', 'fBM'],
		component: 'FbmSimulator',
	},
	{
		title: 'Nitor Energy Forecasting Competition 2026',
		href: 'https://github.com/OskarAllerslev/Nitor-energy-competition-2026',
		description:
			'Predictive machine learning pipeline forecasting highly volatile energy spot prices across 6 distinct markets. Optimized for RMSE utilizing specialized XGBoost models and domain-specific meteorological features.',
		tags: ['R', 'tidymodels', 'XGBoost', 'Machine Learning'],
	},
	{
		title: 'Lifepack (R Package)',
		href: 'https://github.com/OskarAllerslev/lifepack',
		description:
			'Comprehensive R package for life insurance mathematics. Implements robust object-oriented programming (OOP), unit testing, and full roxygen2 documentation for production use.',
		tags: ['R', 'devtools', 'OOP', 'Unit Testing'],
	},
];
---

<Layout title="Oskar Allerslev | Portfolio">
	<main class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
		<!-- Hero Section -->
		<section class="animate-[fadeIn_1s_ease-out] text-center">
			<h1 class="text-4xl font-bold tracking-tight text-zinc-100 sm:text-6xl">Oskar Allerslev</h1>
			<h2 class="mt-4 text-lg font-medium tracking-tight text-teal-400 sm:text-2xl">
				Quantitative Infrastructure & Actuarial Engineering
			</h2>
			<p class="mt-6 mx-auto max-w-3xl text-lg text-zinc-400">
				MSc Actuarial Mathematics student at UCPH and Student Actuary at PFA Pension. I specialize
				in quantitative risk management (QRM), stochastic calculus, and machine learning. My focus
				is translating advanced mathematical theory into scalable, low-latency pricing engines and
				infrastructure using C++, Rust, and R.
			</p>
			<div class="mt-10 flex items-center justify-center gap-4">
				<a
					href="/CV_Oskar_Allerslev.pdf"
					download="CV_Oskar_Allerslev.pdf"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-block rounded-md border border-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-200 transition-all hover:border-teal-500/50 hover:bg-teal-500/10 hover:text-teal-400 hover:shadow-[0_0_15px_rgba(20,184,166,0.3)]"
				>
					Download CV (PDF)
				</a>
				<a
					href="https://dk.linkedin.com/in/oskar-allerslev-2583031ba"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-block rounded-md border border-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-200 transition-all hover:border-teal-500/50 hover:bg-teal-500/10 hover:text-teal-400 hover:shadow-[0_0_15px_rgba(20,184,166,0.3)]"
				>
					LinkedIn
				</a>
			</div>
		</section>

		<!-- Bento Box Projects Grid -->
		<section class="mt-24">
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
				{/* Profile Image Card */}
				<div
					class:list={[
						'group flex flex-col min-h-80 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-xl hover:shadow-white/5 border border-white/10 bg-white/5 rounded-2xl overflow-hidden backdrop-blur-sm opacity-0 animate-fadeIn',
					]}
					style={`animation-delay: ${300 + 0 * 150}ms;`}
				>
					<ProfileImageCard client:only="react" />
				</div>

				{/* Experience Card */}
				<div
					class:list={[
						'group p-6 flex flex-col min-h-80 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-xl hover:shadow-white/5 border border-white/10 bg-white/5 rounded-2xl overflow-hidden backdrop-blur-sm opacity-0 animate-fadeIn',
					]}
					style={`animation-delay: ${300 + 1 * 150}ms;`}
				>
					<ExperienceCard client:only="react" />
				</div>

				{/* Beyond Code Card */}
				<div
					class:list={[
						'group p-6 flex flex-col min-h-80 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-xl hover:shadow-white/5 border border-white/10 bg-white/5 rounded-2xl overflow-hidden backdrop-blur-sm opacity-0 animate-fadeIn',
					]}
					style={`animation-delay: ${300 + 2 * 150}ms;`}
				>
					<BeyondCodeCard client:only="react" />
				</div>

				{/* Tech Stack Card */}
				<div
					class:list={[
						'group p-6 flex flex-col min-h-80 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-xl hover:shadow-white/5 border border-white/10 bg-white/5 rounded-2xl overflow-hidden backdrop-blur-sm opacity-0 animate-fadeIn md:col-span-2 lg:col-span-3',
					]}
					style={`animation-delay: ${300 + 3 * 150}ms;`}
				>
					<TechStackCard client:only="react" />
				</div>
				{
					projects.map((project, i) => {
						const colSpan = i === 0 ? 'md:col-span-2 lg:col-span-2' : '';
						return (
							<div
								class:list={[
									'group p-6 flex flex-col min-h-80 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-xl hover:shadow-white/5 border border-white/10 bg-white/5 rounded-2xl overflow-hidden backdrop-blur-sm opacity-0 animate-fadeIn',
									colSpan,
								]}
								style={`animation-delay: ${300 + (4 + i) * 150}ms;`}
							>
								<div class="flex-grow">
									<a href={project.href} target="_blank" rel="noopener noreferrer" class="hover:underline">
										<h4 class="text-lg font-bold text-zinc-100">{project.title}</h4>
									</a>
									<p class="mt-2 text-sm text-zinc-400 line-clamp-2">{project.description}</p>

									{project.component === 'RustApiExplorer' && <RustApiExplorer client:load />}
									{project.component === 'FbmSimulator' && <FbmSimulator client:load />}

									{project.title === 'Lifepack (R Package)' && (
										<div class="mt-4">
											<div class="rounded-md border border-zinc-800 bg-zinc-950 p-3 font-mono text-xs overflow-x-auto">
												<div class="flex">
													<span class="text-blue-400 mr-2 flex-shrink-0">&gt;</span>
													<code class="text-zinc-300">library(lifepack)</code>
												</div>
												<div class="flex">
													<span class="text-blue-400 mr-2 flex-shrink-0">&gt;</span>
													<code class="text-zinc-300">
														Lambda &lt;- function(x) matrix(c(-0.1, 0.1, 0.05, -0.05), 2, 2)
													</code>
												</div>
												<div class="flex">
													<span class="text-blue-400 mr-2 flex-shrink-0">&gt;</span>
													<code class="text-zinc-300">R &lt;- function(x, mu) matrix(c(mu, 0, 0, mu), 2, 2)</code>
												</div>
												<div class="flex">
													<span class="text-blue-400 mr-2 flex-shrink-0">&gt;</span>
													<code class="text-zinc-300">dR &lt;- function(x, mu) matrix(c(0.1, 0, 0, 0.1), 2, 2)</code>
												</div>
												<div class="flex">
													<span class="text-blue-400 mr-2 flex-shrink-0">&gt;</span>
													<code class="text-zinc-300">
														equiv_premium(0, 80, Lambda, R, dR, 0.05, 0.03, 100)
													</code>
												</div>
												<div class="flex">
													<span class="text-zinc-500 mr-2 flex-shrink-0">[1]</span>
													<code class="text-terminal-green">0.04512</code>
												</div>
											</div>
											<div class="mt-4">
												<a
													href="https://cran.r-project.org/web/packages/lifepack/index.html"
													target="_blank"
													rel="noopener noreferrer"
													class="inline-block rounded-md bg-zinc-800 px-3 py-1 text-xs font-semibold text-zinc-300 transition hover:bg-zinc-700"
												>
													View on CRAN
												</a>
											</div>
										</div>
									)}
								</div>

								<div class="mt-4 flex flex-wrap gap-2">
									{project.tags.map((tag) => (
										<span class="rounded bg-zinc-800 px-2 py-1 font-mono text-xs font-medium text-teal-400">
											{tag}
										</span>
									))}
								</div>
							</div>
						);
					})
				}


				{/* LeetCode Stats Card */}
				<div
					class:list={[
						'group p-6 flex flex-col min-h-80 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-xl hover:shadow-white/5 border border-white/10 bg-white/5 rounded-2xl overflow-hidden backdrop-blur-sm opacity-0 animate-fadeIn',
					]}
					style={`animation-delay: ${300 + (projects.length + 4) * 150}ms;`}
				>
					<LeetCodeCard client:only="react" />
				</div>

				{/* GitHub Contributions Card */}
				<div
					class:list={[
						'md:col-span-2 lg:col-span-3 group p-6 flex flex-col min-h-80 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-xl hover:shadow-white/5 border border-white/10 bg-white/5 rounded-2xl overflow-hidden backdrop-blur-sm opacity-0 animate-fadeIn',
					]}
					style={`animation-delay: ${300 + (projects.length + 5) * 150}ms;`}
				>
					<div class="flex-grow">
						<a
							href="https://github.com/oskarallerslev"
							target="_blank"
							rel="noopener noreferrer"
							class="hover:underline"
						>
							<h4 class="text-lg font-bold text-zinc-100">GitHub Contributions</h4>
						</a>
						<p class="mt-2 text-sm text-zinc-400">Min kodeaktivitet det seneste år.</p>

						<div class="mt-4 flex justify-center items-center h-full">
							<GitHubCard client:only="react" />
						</div>
					</div>

					<div class="mt-4 flex flex-wrap gap-2">
						<span class="rounded bg-zinc-800 px-2 py-1 font-mono text-xs font-medium text-teal-400">
							GitHub
						</span>
						<span class="rounded bg-zinc-800 px-2 py-1 font-mono text-xs font-medium text-teal-400">
							Activity
						</span>
					</div>
				</div>
			</div>
		</section>
	</main>

	<footer class="mt-24 py-10 border-t border-zinc-800">
		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center text-zinc-400">
			<p>&copy; {new Date().getFullYear()} Oskar Allerslev. Alle rettigheder forbeholdes.</p>
			<p class="mt-2 text-sm">Bygget med Astro, React & Tailwind CSS. Udrullet på Vercel.</p>
		</div>
	</footer>
</Layout>

